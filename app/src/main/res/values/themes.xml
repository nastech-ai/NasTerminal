<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
     https://material.io/develop/android/theming/dark
    -->

    <!-- TermuxApp Light DarkActionBar theme. -->
    <style name="Theme.TermuxApp.Light.DarkActionBar" parent="Theme.BaseActivity.Light.DarkActionBar"/>
    <!-- TermuxApp Light NoActionBar theme. -->
    <style name="Theme.TermuxApp.Light.NoActionBar" parent="Theme.BaseActivity.Light.NoActionBar"/>

    <!-- TermuxApp DayNight DarkActionBar theme. -->
    <style name="Theme.TermuxApp.DayNight.DarkActionBar" parent="Theme.BaseActivity.DayNight.DarkActionBar"/>
    <!-- TermuxApp DayNight NoActionBar theme. -->
    <style name="Theme.TermuxApp.DayNight.NoActionBar" parent="Theme.BaseActivity.DayNight.NoActionBar"/>


    <!-- TermuxActivity DayNight NoActionBar theme — NasTech Dark -->
    <style name="Theme.TermuxActivity.DayNight.NoActionBar" parent="Theme.TermuxApp.DayNight.NoActionBar">
        <!-- NasTech primary dark -->
        <item name="colorPrimary">@color/nastech_bg</item>
        <item name="colorPrimaryVariant">@color/nastech_bg</item>
        <item name="colorAccent">@color/nastech_accent</item>

        <item name="android:windowBackground">@color/nastech_bg</item>
        <item name="android:statusBarColor">@color/nastech_header_bg</item>
        <item name="android:navigationBarColor">@color/nastech_bg</item>

        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>

        <!-- NasTech sidebar dark -->
        <item name="buttonBarButtonStyle">@style/NasTech.Drawer.ButtonBarStyle</item>
        <item name="termuxActivityDrawerBackground">@color/nastech_sidebar_bg</item>
        <item name="termuxActivityDrawerImageTint">@color/nastech_text_dim</item>

        <!-- Extra keys — NasTech styled -->
        <item name="extraKeysButtonTextColor">@color/nastech_text</item>
        <item name="extraKeysButtonActiveTextColor">@color/nastech_accent</item>
        <item name="extraKeysButtonBackgroundColor">@color/nastech_button_bg</item>
        <item name="extraKeysButtonActiveBackgroundColor">@color/nastech_button_pressed</item>
    </style>

    <!-- NasTech Lock Screen theme -->
    <style name="Theme.NasTech.Lock" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/nastech_lock_bg</item>
        <item name="android:statusBarColor">@color/nastech_lock_bg</item>
        <item name="android:navigationBarColor">@color/nastech_lock_bg</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="colorPrimary">@color/nastech_accent</item>
    </style>

    <!-- NasTech Browser theme -->
    <style name="Theme.NasTech.Browser" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/nastech_bg</item>
        <item name="android:statusBarColor">@color/nastech_header_bg</item>
        <item name="colorPrimary">@color/nastech_accent</item>
    </style>

    <!-- NasTech drawer button style -->
    <style name="NasTech.Drawer.ButtonBarStyle" parent="@style/Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/nastech_text_dim</item>
    </style>

    <!-- NasTech quick action buttons in sidebar -->
    <style name="NasTech.QuickButton" parent="@style/Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/nastech_quick_btn_text</item>
        <item name="android:textSize">11sp</item>
        <item name="strokeColor">@color/nastech_accent_dim</item>
        <item name="backgroundTint">@color/nastech_quick_btn_bg</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- NasTech Settings theme (single definition — duplicate in styles.xml removed) -->
    <style name="Theme.NasTech.Settings" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/nastech_bg_surface</item>
        <item name="colorPrimary">@color/nastech_accent</item>
        <item name="colorPrimaryVariant">@color/nastech_header_bg</item>
        <item name="colorSurface">@color/nastech_bg_surface</item>
        <item name="android:statusBarColor">@color/nastech_header_bg</item>
        <item name="android:textColorPrimary">@color/nastech_text</item>
        <item name="android:textColorSecondary">@color/nastech_text_dim</item>
    </style>

</resources>
