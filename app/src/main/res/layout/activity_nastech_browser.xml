<?xml version="1.0" encoding="utf-8"?>
<!--
    NasTech AI Terminal — Browser Layout
    Chromium WebView with full toolbar: back, forward, home, address bar,
    refresh, AI, share, close. Plus fullscreen video overlay container.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/nastech_bg">

    <!-- ── Browser toolbar ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/nastech_header_bg"
        android:paddingStart="2dp"
        android:paddingEnd="2dp">

        <!-- Back -->
        <ImageButton
            android:id="@+id/nastech_browser_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_rew"
            android:background="@null"
            android:contentDescription="Back"
            android:alpha="0.35"
            app:tint="@color/nastech_text_dim" />

        <!-- Forward -->
        <ImageButton
            android:id="@+id/nastech_browser_forward"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_ff"
            android:background="@null"
            android:contentDescription="Forward"
            android:alpha="0.35"
            app:tint="@color/nastech_text_dim" />

        <!-- Home -->
        <ImageButton
            android:id="@+id/nastech_browser_home"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:background="@null"
            android:contentDescription="Home (DuckDuckGo)"
            app:tint="@color/nastech_text_dim" />

        <!-- Address bar -->
        <EditText
            android:id="@+id/nastech_browser_address"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@color/nastech_button_bg"
            android:textColor="@color/nastech_text"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:singleLine="true"
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:hint="Search or enter URL"
            android:textColorHint="@color/nastech_text_dim" />

        <!-- Refresh / Stop -->
        <ImageButton
            android:id="@+id/nastech_browser_refresh"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@null"
            android:contentDescription="Refresh"
            app:tint="@color/nastech_text_dim" />

        <!-- AI Chat -->
        <ImageButton
            android:id="@+id/nastech_browser_ai"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_dialog_info"
            android:background="@null"
            android:contentDescription="Ask NasTech AI"
            app:tint="@color/nastech_accent" />

        <!-- Share -->
        <ImageButton
            android:id="@+id/nastech_browser_share"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_share"
            android:background="@null"
            android:contentDescription="Share URL"
            app:tint="@color/nastech_text_dim" />

        <!-- Close -->
        <ImageButton
            android:id="@+id/nastech_browser_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@null"
            android:contentDescription="Close"
            app:tint="@color/nastech_accent" />

    </LinearLayout>

    <!-- ── Progress bar ─────────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/nastech_browser_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:visibility="gone"
        android:progressTint="@color/nastech_accent"
        android:max="100" />

    <!-- ── WebView ──────────────────────────────────────────────────── -->
    <WebView
        android:id="@+id/nastech_browser_webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ── Fullscreen video overlay (shown on top when video goes fullscreen) -->
    <FrameLayout
        android:id="@+id/nastech_browser_fullscreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:visibility="gone" />

</LinearLayout>
