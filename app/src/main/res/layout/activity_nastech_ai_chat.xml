<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/nastech_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/nastech_header_bg"
        android:paddingStart="16dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nastech_ai_button"
            android:textColor="@color/nastech_accent"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nastech_chat_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/nastech_text_dim"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/nastech_chat_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@null"
            android:contentDescription="Close"
            app:tint="@color/nastech_text_dim" />

    </LinearLayout>

    <!-- Chat messages -->
    <ScrollView
        android:id="@+id/nastech_chat_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="12dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/nastech_chat_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp" />

    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nastech_divider" />

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/nastech_header_bg"
        android:paddingStart="12dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/nastech_chat_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/nastech_ai_placeholder"
            android:textColor="@color/nastech_text"
            android:textSize="14sp"
            android:background="@null"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:minLines="1" />

        <ImageButton
            android:id="@+id/nastech_chat_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@null"
            android:contentDescription="Send"
            app:tint="@color/nastech_accent" />

    </LinearLayout>

</LinearLayout>
